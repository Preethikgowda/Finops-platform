# ============================================================
# AWS FinOps Cost Anomaly Detector — Environment Configuration
# Copy this file to .env and fill in all values for local dev.
# NEVER commit .env to version control.
# ============================================================

# ---- AWS ----
AWS_REGION=ap-south-1
# AWS credentials are taken from ~/.aws/credentials, IAM role,
# or the following env vars for local testing only:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token (if using temporary credentials)

# ---- DynamoDB ----
# Table for cost baselines, idempotency tokens, and CloudTrail query cache.
# Must match the Terraform-provisioned table name (see terraform/dynamodb.tf).
DYNAMODB_TABLE_NAME=finops-cost-baselines

# ---- CloudTrail + Athena ----
# S3 bucket where CloudTrail logs are stored
CLOUDTRAIL_S3_BUCKET=your-cloudtrail-bucket
# Key prefix for CloudTrail log objects
CLOUDTRAIL_S3_PREFIX=AWSLogs/
# S3 bucket for Athena query results (separate from CloudTrail bucket)
ATHENA_RESULTS_BUCKET=your-athena-results-bucket
# Athena database and table names for CloudTrail logs
ATHENA_DATABASE=cloudtrail_logs
ATHENA_TABLE=cloudtrail

# ---- Slack ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ---- Bedrock — Amazon Nova Pro ----
# Amazon Nova Pro: cost-effective, fast, AWS-native model for FinOps analysis.
# Model pricing: https://aws.amazon.com/bedrock/pricing/
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# ---- Cost Analysis ----
# Percentage increase above the 7-day rolling average that triggers an alert
COST_THRESHOLD_PCT=15.0
# Number of days in the rolling average baseline window
ROLLING_WINDOW_DAYS=7

# ---- Dashboard ----
# Optional link shown in Slack alerts
COST_DASHBOARD_URL=https://console.aws.amazon.com/cost-management/home

# ---- Logging ----
LOG_LEVEL=INFO
