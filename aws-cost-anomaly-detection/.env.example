# ============================================================
# AWS Cost Anomaly Detector — Environment Configuration
# Copy this file to .env and fill in all values for local dev.
# NEVER commit .env to version control.
# ============================================================

# ---- AWS ----
AWS_REGION=us-east-1
# AWS credentials are taken from ~/.aws/credentials, IAM role,
# or the following env vars for local testing only:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token (if using temporary credentials)

# ---- Elasticsearch ----
ES_HOST=my-es-cluster.example.com
ES_PORT=9200
ES_SCHEME=https
ES_USERNAME=
ES_PASSWORD=
ES_API_KEY=
ES_CA_CERTS=
ES_VERIFY_CERTS=true

# Index prefixes (wildcards applied automatically, e.g. aws-costs-*)
ES_INDEX_PREFIX=aws-costs
ES_DEPLOY_INDEX_PREFIX=deployment-logs
ES_INFRA_INDEX_PREFIX=infra-events

# How many days of historical cost data to query from ES for the rolling window
ES_HISTORICAL_DAYS=30

# ---- Slack ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ---- Bedrock ----
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ---- Cost Analysis ----
# Percentage increase above the 7-day rolling average that triggers an alert
COST_THRESHOLD_PCT=15.0
# Number of days in the rolling average baseline window
ROLLING_WINDOW_DAYS=7

# ---- DynamoDB ----
# Table name for idempotency tracking (must match Terraform output)
DYNAMODB_TABLE=cost-anomaly-detector-prod-idempotency

# ---- Dashboard ----
# Optional link shown in Slack alerts
COST_DASHBOARD_URL=https://console.aws.amazon.com/cost-management/home

# ---- Logging ----
LOG_LEVEL=INFO
